#!/bin/bash

# ------------------------------------------------------------------------------
# PATH
# ------------------------------------------------------------------------------
export PATH="$HOME/dotfiles/bin:$HOME/.local/bin:$PATH"

# Dumb terminal / Emacs comint — skip all fancy setup
if [[ "$TERM" == "dumb" || "$INSIDE_EMACS" == *comint* ]]; then
    PS1="$ "
    return
fi

# ------------------------------------------------------------------------------
# History
# ------------------------------------------------------------------------------
HISTSIZE=5000000
HISTFILESIZE=5000000
HISTTIMEFORMAT="%F %T  "
HISTCONTROL=ignorespace:erasedups
shopt -s histappend

# ------------------------------------------------------------------------------
# Aliases
# ------------------------------------------------------------------------------
alias ls='ls -GFh --color=auto'
alias ll='ls -lh --color=auto'

# ------------------------------------------------------------------------------
# Emacs keybindings
# ------------------------------------------------------------------------------
set -o emacs

# ------------------------------------------------------------------------------
# Bash completion
# ------------------------------------------------------------------------------
if [ -f /usr/share/bash-completion/bash_completion ]; then
    source /usr/share/bash-completion/bash_completion
elif [ -f /etc/bash_completion ]; then
    source /etc/bash_completion
fi

# ------------------------------------------------------------------------------
# Lazy conda
# ------------------------------------------------------------------------------
_lazy_conda_init() {
    unset -f conda mamba activate
    local conda_setup
    if [ -f "$HOME/miniforge3/etc/profile.d/conda.sh" ]; then
        conda_setup="$HOME/miniforge3"
    elif [ -f "$HOME/miniconda3/etc/profile.d/conda.sh" ]; then
        conda_setup="$HOME/miniconda3"
    elif [ -f "$HOME/anaconda3/etc/profile.d/conda.sh" ]; then
        conda_setup="$HOME/anaconda3"
    fi
    if [ -n "$conda_setup" ]; then
        eval "$("$conda_setup/bin/conda" shell.bash hook)"
        if [ -f "$conda_setup/etc/profile.d/mamba.sh" ]; then
            source "$conda_setup/etc/profile.d/mamba.sh"
        fi
    fi
}

conda()    { _lazy_conda_init; conda "$@"; }
mamba()    { _lazy_conda_init; mamba "$@"; }
activate() { _lazy_conda_init; conda activate "$@"; }

# ------------------------------------------------------------------------------
# Starship prompt (must come after vterm setup)
# ------------------------------------------------------------------------------
# eval "$(starship init bash)"

# ------------------------------------------------------------------------------
# Git prompt
# ------------------------------------------------------------------------------
GIT_PS1_SHOWDIRTYSTATE=1
GIT_PS1_SHOWUPSTREAM="auto"
GIT_PS1_SHOWUNTRACKEDFILES=1
if [ -f /usr/share/bash-completion/git-prompt.sh ]; then
    source /usr/share/bash-completion/git-prompt.sh
elif [ -f /usr/share/git-core/contrib/completion/git-prompt.sh ]; then
    source /usr/share/git-core/contrib/completion/git-prompt.sh
fi

# ------------------------------------------------------------------------------
# Prompt
# ------------------------------------------------------------------------------
__my_prompt() {
    local exit=$?

    # Colors
    local reset='\[\e[0m\]'
    local bold='\[\e[1m\]'
    local cyan='\[\e[36m\]'
    local yellow='\[\e[33m\]'
    local green='\[\e[32m\]'
    local red='\[\e[31m\]'
    local magenta='\[\e[35m\]'
    local blue='\[\e[34m\]'

    local conda_part=""
    if [[ -n "$CONDA_DEFAULT_ENV" ]]; then
        conda_part=" (${magenta}🅒 ${CONDA_DEFAULT_ENV}${reset})"
    fi

    # Git info
    local git_part=""
    if declare -f __git_ps1 > /dev/null; then
        git_part="($(__git_ps1 " ${green}on  %s${reset}"))"
    fi

    # Exit code — only show on failure
    local exit_part=""
    if [[ $exit -ne 0 ]]; then
        exit_part=" $({red}✘${exit}${reset})"
    fi

    # Line 1: path  git  conda  exit
    # Line 2: ❯
    PS1="${yellow}${bold}\w${reset}${git_part}${conda_part}${exit_part}\n${cyan}❯${reset} "

    # vterm: directory tracking + prompt location (must be last)
    if [[ "$INSIDE_EMACS" == "vterm" ]]; then
        PS1="${PS1}"'\[$(vterm_prompt_end)\]'
    fi
}

PROMPT_COMMAND="__my_prompt"

# ------------------------------------------------------------------------------
# Emacs vterm integration
# ------------------------------------------------------------------------------

if [[ "$INSIDE_EMACS" == "vterm" ]]; then
    # Source the official vterm shell integration if available
    VTERM_BASH="${EMACS_VTERM_PATH}/etc/emacs-vterm-bash.sh"
    if [ -f "$VTERM_BASH" ]; then
        source "$VTERM_BASH"
    fi
    # Get vterm prompt tracking to play nice with starship
    vterm_prompt_end(){
	vterm_printf "51;A$(whoami)@$(hostname):$(pwd)"
    }
    __vterm_starship_hook() {
        PS1="${PS1}"'\[$(vterm_prompt_end)\]'
    }
    starship_precmd_user_func="__vterm_starship_hook"
    # nate-agent shell command hooks
    __nate_begin() { true; }
    __nate_end()   { vterm_cmd nate-agent-command-end "$1" "$2" "$3"; }
fi
